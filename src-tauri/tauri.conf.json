{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "49modman",
  "version": "0.0.1",
  "identifier": "com.therealcrast.49modman",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:4173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "49modman",
        "width": 1360,
        "height": 860,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "targets": [
      "msi",
      "appimage"
    ],
    "windows": {
      "wix": {
        "upgradeCode": "A6A2640F-44A8-4D68-B7E2-26A45B782A16"
      }
    }
  }
}
